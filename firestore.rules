rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // API config (budget kill switch) — read-only for clients, written by Cloud Functions
    match /config/{docID} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Route leaderboard: parent document and completed runs
    match /routeLeaderboards/{routeID} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /runs/{docID} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // User profiles
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Shared route library
    match /sharedRoutes/{docID} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['runCount']);
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
  }
}
